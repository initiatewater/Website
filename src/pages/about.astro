---
/*
  pages/about.astro
  Page "About Us" / Home (même contenu selon la maquette).

  Structure desktop : texte gauche / bulles statistiques + drop shapes droite
  Structure mobile  : colonne unique, bulles en grille flex 2 colonnes
*/
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="About Us"
  description="Initiate connects PhD candidates working on freshwater challenges worldwide."
>

  <!--
    page-grid : 2 colonnes desktop (5fr/7fr), 1 colonne mobile.
    Défini dans global.css — pas besoin de répéter les breakpoints ici.
  -->
  <div class="page-grid">


    <!-- ══════════════════════════════════════════════════════════
         COLONNE GAUCHE : texte
         pr-16 sur desktop : espace entre le texte et la colonne visuelle
    ══════════════════════════════════════════════════════════ -->
    <div class="flex flex-col justify-center pr-0 md:pr-16">

      <!-- Titre principal -->
      <h1 class="text-i-navy mb-6">
        The initiate<br />program !
      </h1>

      <!-- Corps de texte : opacity-75 pour le contraste doux observé dans les maquettes -->
      <p class="text-i-navy opacity-75 max-w-xs mb-10">
        Are you a PhD candidate working on water-related challenges?
        Do you want to connect with peers, experts, and mentors from
        around the world to develop innovative solutions for global
        water sustainability?
      </p>

      <!-- CTA : composant .btn-outline défini dans global.css -->
      <a href="/apply" class="btn-outline">
        Candidater ici
      </a>
    </div>


    <!-- ══════════════════════════════════════════════════════════
         COLONNE DROITE : bulles statistiques + drop shapes

         DESKTOP (md:block) : positionnement absolu dans un conteneur
         de hauteur fixe. Les drop shapes et bulles se superposent librement.

         MOBILE (flex) : grille flex simple, sans positionnement absolu.
         Les drop shapes disparaissent sur mobile (décoration non essentielle).
    ══════════════════════════════════════════════════════════ -->

    <!--
      VISUEL DESKTOP
      md:flex → visible uniquement ≥768px
      relative overflow-hidden : contexte pour les enfants positionnés en absolu
      La hauteur est héritée de page-grid (align-items: center / min-height: 100vh)
    -->
    <div class="hidden md:flex relative w-full h-full min-h-[480px] items-center justify-center">

      <!-- ── DROP SHAPES ─────────────────────────────────────────────────
        Formes organiques décoratives derrière les bulles.
        Positionnement approximé depuis les maquettes.
        Pour ajuster : modifie top/right/left/bottom et width/height en style inline.
      ──────────────────────────────────────────────────────────────────── -->
      <div class="drop-shape"          style="width:145px; height:165px; top:6%;  right:8%;"></div>
      <div class="drop-shape drop-shape--faint" style="width:115px; height:135px; top:18%; right:27%;"></div>
      <div class="drop-shape drop-shape--faint" style="width:95px;  height:115px; top:52%; right:4%;"></div>
      <div class="drop-shape"          style="width:125px; height:145px; bottom:6%; right:18%; opacity:0.22;"></div>
      <div class="drop-shape drop-shape--faint" style="width:80px;  height:100px; bottom:16%; right:38%;"></div>
      <div class="drop-shape drop-shape--faint" style="width:65px;  height:80px;  top:38%; left:2%; opacity:0.15;"></div>

      <!-- ── BULLES STATISTIQUES ──────────────────────────────────────────
        .stat-bubble (global.css) : rounded-full, flex col, items-center, text-white, absolute.
        Dimensions et positions en style inline : trop spécifiques pour Tailwind.

        Pour modifier les chiffres : changer le contenu des <span>.
        Pour modifier les tailles  : changer width/height dans style.
        Pour modifier les positions: changer top/bottom/left/right dans style.
      ──────────────────────────────────────────────────────────────────── -->

      <!-- 126 Doctorants : teal principal, grande bulle, centre-gauche -->
      <div
        class="stat-bubble bg-i-teal z-10"
        style="width:155px; height:155px; top:30%; left:6%;"
      >
        <span class="text-4xl font-bold leading-none">126</span>
        <span class="text-xs font-medium mt-1 opacity-90 tracking-wide">Doctorants</span>
      </div>

      <!-- 12 Universités : navy, bulle la plus grande, haut-droit -->
      <div
        class="stat-bubble bg-i-navy z-10"
        style="width:180px; height:180px; top:14%; right:10%;"
      >
        <span class="text-5xl font-bold leading-none">12</span>
        <span class="text-xs font-medium mt-1 opacity-90 tracking-wide">Universités</span>
      </div>

      <!-- 3 Cohortes : lime, petite bulle, bas-centre -->
      <div
        class="stat-bubble bg-i-lime z-10"
        style="width:125px; height:125px; bottom:18%; left:28%;"
      >
        <span class="text-4xl font-bold leading-none">3</span>
        <span class="text-xs font-medium mt-1 opacity-90 tracking-wide">Cohortes</span>
      </div>
    </div>


    <!--
      VISUEL MOBILE
      md:hidden → visible uniquement <768px
      Les 3 bulles passent en grille flex : 2 colonnes, 3e centrée en dessous.
      Les drop shapes sont absentes : décoration non essentielle sur petit écran.
    -->
    <div class="flex md:hidden flex-wrap justify-center items-center gap-6 py-8">

      <!-- Rangée 1 : 126 et 12 côte à côte -->
      <div class="flex items-center gap-4">
        <div
          class="rounded-full bg-i-teal flex flex-col items-center justify-center text-white"
          style="width:120px; height:120px;"
        >
          <span class="text-3xl font-bold leading-none">126</span>
          <span class="text-xs font-medium mt-1 opacity-90">Doctorants</span>
        </div>

        <div
          class="rounded-full bg-i-navy flex flex-col items-center justify-center text-white"
          style="width:138px; height:138px;"
        >
          <span class="text-4xl font-bold leading-none">12</span>
          <span class="text-xs font-medium mt-1 opacity-90">Universités</span>
        </div>
      </div>

      <!-- Rangée 2 : 3 seul, centré -->
      <div class="flex justify-center w-full">
        <div
          class="rounded-full bg-i-lime flex flex-col items-center justify-center text-white"
          style="width:100px; height:100px;"
        >
          <span class="text-3xl font-bold leading-none">3</span>
          <span class="text-xs font-medium mt-1 opacity-90">Cohortes</span>
        </div>
      </div>
    </div>

  </div><!-- fin page-grid -->
</BaseLayout>
