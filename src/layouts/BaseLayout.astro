---
import Header from '../components/Header.astro'
import '../styles/global.css'
import { sanityClient, queries } from '../lib/sanity'

interface Props {
  title:       string
  description?: string
  formPage?:   boolean
  navHide?:    boolean
}

const {
  title,
  description,
  formPage  = false,
  navHide   = true,
} = Astro.props

// Fetch des paramètres globaux : visibilité des pages + meta
const settings = await sanityClient.fetch(queries.siteSettings).catch(() => null)
const siteTitle = settings?.siteTitle || 'Initiate'
const metaDesc  = description || settings?.siteDescription || 'Initiate – Connecting PhD candidates in freshwater research worldwide.'
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {siteTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="preload" href="/fonts/SUSE-Regular.woff2" as="font" type="font/woff2" crossorigin />
</head>

<body class:list={[formPage && 'bg-i-cream']} data-nav-hide={navHide ? 'true' : 'false'}>
  <Header settings={settings?.pagesVisibility} />
  <main><slot /></main>
</body>
</html>
